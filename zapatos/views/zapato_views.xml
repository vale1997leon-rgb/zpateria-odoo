<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zapatos_zapato_list" model="ir.ui.view">
        <field name="name">zapatos.zapato.list</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <list string="Zapatos">
                <field name="codigo"/>
                <field name="name"/>
                <field name="talla"/>
                <field name="precio"/>
                <field name="stock"/>
                <field name="activo"/>
            </list>
        </field>
    </record>

    <record id="view_zapatos_zapato_form" model="ir.ui.view">
        <field name="name">zapatos.zapato.form</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <form string="Zapato">
                <sheet>
                    <group>
                        <field name="codigo" readonly="1"/>
                        <field name="name"/>
                        <field name="talla"/>
                        <field name="precio"/>
                        <field name="stock"/>
                        <field name="activo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_zapatos_zapato" model="ir.actions.act_window">
        <field name="name">Zapatos</field>
        <field name="res_model">zapatos.zapato</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_zapatos_root" name="Zapateria"/>
    <menuitem id="menu_zapatos_zapato" name="Zapatos"
              parent="menu_zapatos_root"
              action="action_zapatos_zapato"/>

</odoo>