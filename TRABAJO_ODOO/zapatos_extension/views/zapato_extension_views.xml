<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_zapato_form_extension" model="ir.ui.view">
        <field name="name">zapatos.zapato.form.extension</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapatos_zapato_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='stock']" position="attributes">
                <attribute name="decoration-danger">stock &lt; 10</attribute>
                <attribute name="decoration-warning">stock &gt;= 10 and stock &lt; 30</attribute>
                <attribute name="decoration-success">stock &gt;= 30</attribute>
            </xpath>

            <xpath expr="//group" position="inside">
                <field name="codigo"/>
                <field name="marca"/>
                <field name="color"/>
                <field name="material"/>
                <field name="stock_minimo"/>
                <field name="valor_inventario" readonly="1"/>
                <field name="descripcion"/>
            </xpath>
        </field>
    </record>

    <record id="view_zapato_list_extension" model="ir.ui.view">
        <field name="name">zapatos.zapato.list.extension</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapatos_zapato_list"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='stock']" position="attributes">
                <attribute name="decoration-danger">stock &lt; 10</attribute>
                <attribute name="decoration-warning">stock &gt;= 10 and stock &lt; 30</attribute>
                <attribute name="decoration-success">stock &gt;= 30</attribute>
            </xpath>

            <xpath expr="//list" position="inside">
                <field name="codigo"/>
                <field name="marca"/>
                <field name="color"/>
                <field name="valor_inventario"/>
            </xpath>
        </field>
    </record>
</odoo>